@model IEnumerable<SmartCarRentACar.Models.Car>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cars";
}

<div class="container my-5" style="min-height:70vh;">

    <h2 class="text-center fw-bold mb-4">Available Cars</h2>

    <div class="row g-4 justify-content-center">

        @foreach (var car in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="card h-100 shadow-sm border-0 rounded-4 text-center">

                    <img src="@car.ImageUrl"
                         alt="@car.Model"
                         class="card-img-top rounded-top-4"
                         style="height:150px; object-fit:cover;" />

                    <div class="card-body">

                        <h5 class="fw-bold mb-1">@car.Model</h5>
                        <h6 class="text-muted mb-2">@car.CarName</h6>

                        <p class="fw-semibold text-primary mb-3">
                            PKR @car.PricePerDay / day
                        </p>

                        <a href="/Home/CarDetails/@car.Id"
                           class="btn btn-primary btn-sm w-100">
                            View Details
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>
